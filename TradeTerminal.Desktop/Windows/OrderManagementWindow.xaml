<Window x:Class="TradeTerminal.Desktop.Windows.OrderManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TradeTerminal.Desktop.Windows"
        mc:Ignorable="d"
        Title="Управление заказами" Height="500" Width="700"
        WindowStartupLocation="CenterOwner" Background="White" FontFamily="Calibri"
        Loaded="Window_Loaded"
        >
    <Grid Margin="15,15,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Номер заказа:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtOrderNumber" Width="100" VerticalAlignment="Center"/>
            <Button Content="Найти" Click="FindOrderButton_Click" Style="{StaticResource PrimaryButton}" Padding="10,3,10,3" FontSize="12" Margin="10,0,0,0"/>
            <Button Content="Обновить" Click="RefreshButton_Click" Style="{StaticResource PrimaryButton}" Padding="10,3,10,3" FontSize="12" Margin="10,0,0,0"/>
        </StackPanel>

        <ListView x:Name="ordersListView" Grid.Row="1" SelectionChanged="OrdersListView_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="№" Width="50" DisplayMemberBinding="{Binding OrderNumber}"/>
                    <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy}}"/>
                    <GridViewColumn Header="Клиент" Width="150" DisplayMemberBinding="{Binding UserFullName}"/>
                    <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding StatusName}"/>
                    <GridViewColumn Header="Сумма" Width="100">
                        <GridViewColumn.DisplayMemberBinding>
                            <Binding Path="TotalAmount" StringFormat="{}{0:C}" ConverterCulture="ru-RU"/>
                        </GridViewColumn.DisplayMemberBinding>
                    </GridViewColumn>
                    <GridViewColumn Header="Код" Width="70" DisplayMemberBinding="{Binding PickupCode}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2" Background="#F5F5F5" Padding="15,15,15,15" Margin="0,10,0,0" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Статус:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Column="1" x:Name="cmbStatus" Width="120" VerticalAlignment="Center" SelectionChanged="StatusComboBox_SelectionChanged"/>

                <TextBlock Grid.Column="2" Text="Дата доставки:" VerticalAlignment="Center" Margin="15,0,10,0"/>
                <DatePicker Grid.Column="3" x:Name="dpDeliveryDate" Width="120" VerticalAlignment="Center" SelectedDateChanged="DpDeliveryDate_SelectedDateChanged"/>

                <Button Grid.Column="4" Content="Удалить" Click="DeleteOrderButton_Click" 
                        Style="{StaticResource PrimaryButton}" Padding="10,3,10,3" FontSize="12" 
                        Background="DarkRed" Margin="15,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
